{
	"name": "n8n-nodes-telegram-grampro",
	"version": "4.0.3",
	"description": "Telegram GramPro is Advanced n8n node for Telegram MTProto automation using GramJS, featuring user account triggers and 2FA support.",
	"license": "MIT",
	"keywords": [
		"n8n",
		"n8n-nodes",
		"n8n-community-node-package",
		"n8n-community-node",
		"telegram",
		"telegram-api",
		"telegram-mtproto",
		"telegram-user",
		"telegram-grampro",
		"telegram-js",
		"GramPro",
		"gramjs",
		"workflow automation",
		"userbot",
		"selfbot",
		"client API",
		"marketing automation",
		"message monitoring",
		"auto-responder",
		"scraper"
	],
	"packageManager": "pnpm@10.32.1",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "rimraf dist && tsc && gulp build:icons",
		"test": "pnpm run lint && pnpm run build",
		"format": "prettier src/core src/credentials src/nodes src/nodes/resources src/types src/index.ts --write",
		"dev": "tsc --watch",
		"lint": "eslint src/core src/credentials src/nodes src/nodes/resources src/types src/index.ts",
		"lint:fix": "eslint src/core src/credentials src/nodes src/nodes/resources src/types src/index.ts --fix",
		"n8n-scan": "pnpm dlx @n8n/scan-community-package .",
		"prepublishOnly": "pnpm run lint && pnpm run build"
	},
	"author": {
		"name": "sadiakant",
		"email": "krushnakantsadiya@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sadiakant/n8n-nodes-telegram-grampro.git"
	},
	"homepage": "https://github.com/sadiakant/n8n-nodes-telegram-grampro#readme",
	"bugs": {
		"url": "https://github.com/sadiakant/n8n-nodes-telegram-grampro/issues"
	},
	"dependencies": {
		"telegram": "^2.26.22"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/crypto-js": "^4.2.2",
		"@types/node": "^25.4.0",
		"@typescript-eslint/parser": "8.57.0",
		"esbuild": "^0.27.4",
		"eslint": "^10.0.3",
		"eslint-plugin-n8n-nodes-base": "^1.16.6",
		"globals": "^17.4.0",
		"gulp": "^5.0.1",
		"n8n-workflow": "^2.12.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	},
	"peerDependencies": {
		"n8n-workflow": "^1.120.0 || ^2.0.0"
	},
	"n8n": {
		"nodes": [
			"dist/nodes/TelegramMtproto.node.js",
			"dist/nodes/TelegramTrigger.node.js"
		],
		"credentials": [
			"dist/credentials/TelegramApi.credentials.js"
		]
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18.17.0"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public",
		"provenance": true
	}
}